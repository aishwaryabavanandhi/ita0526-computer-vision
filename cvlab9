import cv2

# Read image
img = cv2.imread(r"C:\Users\B Aishwarya\Downloads\labprac.jpg")

if img is None:
    print("Error: Image not found!")
else:
    # Get original dimensions
    height, width = img.shape[:2]

    # Resize to bigger size (2x scale)
    bigger = cv2.resize(img, None, fx=2, fy=2, interpolation=cv2.INTER_LINEAR)

    # Resize to smaller size (0.5x scale)
    smaller = cv2.resize(img, None, fx=0.5, fy=0.5, interpolation=cv2.INTER_AREA)

    # Display images
    cv2.imshow("Original Image", img)
    cv2.imshow("Bigger Image", bigger)
    cv2.imshow("Smaller Image", smaller)

    cv2.waitKey(0)
    cv2.destroyAllWindows()