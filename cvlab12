import cv2

# Read image
img = cv2.imread(r"C:\Users\B Aishwarya\Downloads\labprac.jpg")

if img is None:
    print("Error: Image not found!")
else:
    # Rotate 270 degrees clockwise
    rotated = cv2.rotate(img, cv2.ROTATE_90_COUNTERCLOCKWISE)

    # Display images
    cv2.imshow("Original Image", img)
    cv2.imshow("Rotated 270° Image", rotated)

    cv2.waitKey(0)
    cv2.destroyAllWindows()