import cv2

# Read image
img = cv2.imread(r"C:\Users\B Aishwarya\Downloads\labprac.jpg")

if img is None:
    print("Error: Image not found!")
else:
    # Crop region (ROI)
    roi = img[100:300, 100:300]

    # Copy and paste ROI to another location
    img[350:550, 350:550] = roi

    # Display images
    cv2.imshow("Original Image", img)
    cv2.imshow("Cropped ROI", roi)

    cv2.waitKey(0)
    cv2.destroyAllWindows()